{
    "name": "Vibes",
    "menuBackgroundImage": "https://sirvibesalot.github.io/TCG-Arena-Vibes/assets/backgrounds/VibesTCG_LandingPage_16x9.webp",
    "cardRotation": "90",
    "deckBuilding": {
        "mainFilters": [
            "color",
            "type",
            "cost",
            "set",
            "subtype"
        ],
        "formats": [
            {
                "title": "Classic",
                "gameplay": "Classic",
                "legalityCode": "COR",
                "deckRuleset": "Classic"
            }
        ],
        "deckRulesets": {
            "Classic": {
                "general": {
                    "min": 52,
                    "maxPerCard": 4
                }
            }
        }
    },
    "gameplay": {
        "Classic": {
            "mulligan": {
                "startingHandSize": 5,
                "mulliganCount": {
                    "max": 1
                },
                "mulliganCycle": {
                    "info": "You put as many as you want of the five cards in your hand to the bottom of your deck then draw the same number of new cards as you put back from the top of your deck.",
                    "steps": [
                        "toBottom",
                        "draw"
                    ]
                }
            },
            "newTurn": {
                "drawOnStart": false,
                "sharedTurn": true
            },
            "countersStartingValues": [
                0
            ],
            "hideFacedDownCards": true,
            "sections": {
                "customSections": [
                    "Huddle",
                    "Mana",
                    "FirstPlayer"
                ],
                "layout": {
                    "direction": "column",
                    "isSymetricalForOpponents": false,
                    "content": [
                        {
                            "section": "FirstPlayer"
                        },
                        {
                            "direction": "row",
                            "style": false,
                            "content": [
                                {
                                    "section": "Huddle"
                                }
                            ]
                        },
                        {
                            "direction": "row",
                            "style": false,
                            "content": [
                                {
                                    "section": "Mana"
                                },
                                {
                                    "section": "Fishsicles",
                                    "style": {
                                        "width": "11vh"
                                    }
                                }
                            ]
                        }
                    ]
                },
                "autoPlayFromHand": {
                    "Action": "Stack",
                    "Character": "Huddle",
                    "Fit": "Huddle",
                    "Relic": "Huddle",
                    "Rod": "Mana"
                },
                "autoPlayFromStack": {
                    "Action": "Discard",
                    "Rod": "Mana",
                    "Character": "Huddle",
                    "Fit": "Huddle",
                    "Relic": "Huddle"
                },
                "sectionsDict": {
                    "Stack": {
                        "isDefaultSection": true,
                        "title": "Stack",
                        "isHidden": "no",
                        "height": "HUGE",
                        "alignment": "NONE",
                        "isHorizontalAllowed": false,
                        "isGroupForbidden": true,
                        "displayedTitle": "Stack"
                    },
                    "Huddle": {
                        "title": "Huddle",
                        "isHidden": "no",
                        "height": "MEDIUM",
                        "alignment": "CENTER",
                        "isHorizontalAllowed": true
                    },
                    "Mana": {
                        "title": "Mana",
                        "isHidden": "yes",
                        "height": "SMALL",
                        "alignment": "CENTER",
                        "noAutoPayTo": "true",
                        "isHorizontalAllowed": false,
                        "displayedTitle": "Rods",
                        "isGroupForbidden": false,
                        "showHiddenCardInHistory": false,
                        "logWhenPlayed": true
                    },
                    "Fishsicles": {
                        "title": "Fishsicles",
                        "isHidden": "no",
                        "height": "SMALL",
                        "alignment": "CENTER",
                        "isHorizontalAllowed": false
                    },
                    "FirstPlayer": {
                        "type": "custom",
                        "blueprint": {
                            "type": "div",
                            "props": {
                                "className": "position-absolute bottom-0 start-0 shadow on-section-hovered",
                                "style": {
                                    "height": "4vh",
                                    "width": "4vh",
                                    "borderRadius": "50%",
                                    "zIndex": 1000,
                                    "marginBottom": "3vh",
                                    "marginLeft": "2vh"
                                }
                            },
                            "children": [
                                {
                                    "type": "img",
                                    "props": {
                                        "className": "h-100 w-100",
                                        "style": {
                                            "opacity": "{{game.data.FirstPlayer.enabled ? '1' : '0'}}"
                                        },
                                        "src": "https://sirvibesalot.github.io/TCG-Arena-Vibes/assets/tokens/Baron_Token.webp"
                                    }
                                },
                                {
                                    "type": "button",
                                    "props": {
                                        "className": "hovered-reveal position-absolute top-50 start-50 translate-middle opp-hidden",
                                        "style": {
                                            "display": "{{game.data.FirstPlayer.enabled ? 'none' : 'flex'}}"
                                        }
                                    },
                                    "onClick": "game.data.FirstPlayer.enabled = true; game.data.FirstPlayer.lastOwnerOrderPosition = game.turn.orderPosition; chatLog('has taken the Baron token')",
                                    "children": "Take Baron"
                                }
                            ]
                        },
                        "defaultValue": {
                            "enabled": false,
                            "lastOwnerOrderPosition": -1
                        },
                        "events": {
                            "onStart": "if (game.turn.isMyTurn) { game.data.FirstPlayer = { enabled: true, lastOwnerOrderPosition: game.turn.orderPosition } }",
                            "onOpponentUpdate": "if (opponentGame.data.FirstPlayer.enabled) { game.data.FirstPlayer = { enabled: false, lastOwnerOrderPosition: opponentGame.turn.orderPosition } }",
                            "onNewTurn": "const newFirstPlayer = (game.data.FirstPlayer.lastOwnerOrderPosition + 1) % game.turn.totalPlayers; game.data.FirstPlayer = { enabled: newFirstPlayer === game.turn.orderPosition, lastOwnerOrderPosition: newFirstPlayer }"
                        }
                    }
                }
            }
        }
    },
    "defaultRessources": {
        "backgrounds": [
            "https://sirvibesalot.github.io/TCG-Arena-Vibes/assets/backgrounds/VibesTCG_LandingPage_16x9.webp",
            "https://sirvibesalot.github.io/TCG-Arena-Vibes/assets/playmats/Vibes_WorldChampsPlaymat2026.webp",
            "https://sirvibesalot.github.io/TCG-Arena-Vibes/assets/playmats/Vibes_LordOfLightning-Playmat.webp",
            "https://sirvibesalot.github.io/TCG-Arena-Vibes/assets/playmats/Vibes_AsianChamps2026-Playmat.webp",
            "https://sirvibesalot.github.io/TCG-Arena-Vibes/assets/playmats/Vibes_iron-penguin_playmat.webp"
        ],
        "decksUrl": "https://sirvibesalot.github.io/TCG-Arena-Vibes/VibesDecks.json"
    },
    "customHelp": "To put a card in your rods, drag and drop the card in the rod zone.",
    "cards": {
        "dataUrl": "https://sirvibesalot.github.io/TCG-Arena-Vibes/VibesCards.json",
        "cardBack": "https://sirvibesalot.github.io/TCG-Arena-Vibes/assets/cardbacks/Vibes_DefaultCardBack.webp",
        "cardBackColor": "#0c0f15"
    }
}